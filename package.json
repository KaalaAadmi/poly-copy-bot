    "node-cron": "^3.0.3",
    "telegraf": "^4.16.3",
    "winston": "^3.13.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.3",
