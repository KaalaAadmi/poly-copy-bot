# ========================
# Poly-Bot Configuration
# ========================

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID (your personal chat ID for alerts)
# Your user ID from @userinfobot (numeric)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# MongoDB Atlas Connection String
MONGODB_URI=your_mongodb_connection_string_here

# Starting bankroll in USDC (200 EUR ≈ 215 USDC)
INITIAL_BALANCE=215

# Polling interval in milliseconds (10-15 seconds recommended)
POLL_INTERVAL_MS=12000

# Daily max exposure as decimal (10% = 0.10)
DAILY_MAX_EXPOSURE=0.50

# Position size as decimal (2% = 0.02)
POSITION_SIZE_PCT=0.02

# Polymarket API Base URLs
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
DATA_API_URL=https://data-api.polymarket.com

# ── Live Trading – Polymarket CLOB SDK ──
#
# POLYMARKET_PRIVATE_KEY:
#   Your MetaMask private key (since you signed in with MetaMask).
#   MetaMask → ⋮ → Account Details → Show Private Key
#   (64-char hex string, with or without 0x prefix)
POLYMARKET_PRIVATE_KEY=your_private_key_here
#
# POLYMARKET_SIGNATURE_TYPE:
#   2 = GNOSIS_SAFE (MetaMask / browser wallet login – this is yours)
#   1 = POLY_PROXY  (Magic Link / email login)
#   0 = EOA         (standalone wallet, not a Polymarket account)
POLYMARKET_SIGNATURE_TYPE=2
#
# POLYMARKET_FUNDER_ADDRESS:
#   Your Polymarket PROXY wallet address (NOT your MetaMask address).
#   Find it on polymarket.com → click your profile icon (top right).
#   It's the 0x... address shown in your profile/deposit page.
POLYMARKET_FUNDER_ADDRESS=your_funder_address_here

# WebSocket for real-time market resolution
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ── Catchup – Copy existing whale positions on startup / mode switch / wallet add ──
#
# CATCHUP_ENABLED:
#   When true, the bot will scan all tracked wallets' open positions on:
#   - Bot startup
#   - Mode switch (/golive or /gopaper)
#   - New wallet added (/addwallet)
#   And copy-trade any positions where the price hasn't moved too far.
CATCHUP_ENABLED=true
#
# CATCHUP_MAX_SLIPPAGE:
#   Maximum acceptable price difference (in dollars) between the whale's
#   entry price and the current market price. Default is $0.08 (8 cents).
#   Positions where the price has drifted beyond this are skipped.
CATCHUP_MAX_SLIPPAGE=0.08
#
# CATCHUP_MODE:
#   How the slippage threshold is applied. Two modes:
#
#   "absolute" – Catches up if |current_price - whale_entry| ≤ threshold.
#                Works in both directions (price went up OR down).
#                Use this if you want to catch dips too.
#                Example: whale bought at 40¢, threshold 8¢
#                  → catches up if current price is between 32¢–48¢
#
#   "relative" – Catches up if current_price ≤ whale_entry + threshold.
#                Only blocks if price moved UP beyond the threshold.
#                If price went DOWN (cheaper), it always catches up.
#                Use this if you're OK buying cheaper but not overpaying.
#                Example: whale bought at 40¢, threshold 8¢
#                  → catches up if current price is ≤ 48¢ (any dip is fine)
#
CATCHUP_MODE=relative
